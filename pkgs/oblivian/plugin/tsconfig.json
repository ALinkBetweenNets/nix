{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["DOM", "ES2021"],
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"allowJs": true,
		"importHelpers": true,
		"inlineSourceMap": true,
		"inlineSources": true
	},
	"include": ["src/**/*.ts"]
}
